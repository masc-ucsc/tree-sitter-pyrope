const a = "foo"

mut at1 = (
  ,a:string
)
cassert at1[0] == "foo"
cassert at1 !has "a"    // at1.a undefined

mut at2 = (
  ,a:string = ?
)
cassert at2.a == ""  and at2.a::[valid]==false
at2.a = "torrellas"
cassert at2.a == "torrellas" and at2[0] == "torrellas"

mut at3:at2 = ?
cassert at3.a == ""  and at3.a::[valid]==false

mut at4:at2 = (a="josep")
cassert at4.a == "josep"  and at4.a::[valid] and at4::[valid]

