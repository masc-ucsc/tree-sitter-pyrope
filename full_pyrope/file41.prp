mut a=(mut a=1, mut b=2)
const b=(const c=3)

const ccat1 = a ++ b
assert(ccat1 == (const a=1, const b=2, const c=3))
assert(ccat1 == (1,2,3))

mut ccat2 = a ++ (const b=20) ++ b
assert(ccat2 == (const a=1, const b=(2,20), const c=3))
assert(ccat2 == (1,(2,20),3))

mut join1 = (...a,...b)
assert(join1 == (const a=1, const b=2, const c=3))
assert(join1 == (1,2,3))

