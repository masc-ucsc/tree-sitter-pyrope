x = 0b1_0110   // positive
y = 0s1_0110   // negative
assert x#[0,2] == 0b10
assert y#[100,200]       == 0b11   and x#[100,200]       == 0
assert y#sext[0,100,200] == 0sb110 and x#sext[1,100,200] == 0b001
assert x#|[..] == -1
assert x#&[0,1] == 0
assert x#+[0..=5] == x#+[0..<100] == 3
assert y#[..]#+[..] == 3
assert y#[0..=5]#+[..] == 3
assert y#[0..=6]#+[..] == 4

mut z     = 0b0110
z#[0] = 1
assert z == 0b0111
