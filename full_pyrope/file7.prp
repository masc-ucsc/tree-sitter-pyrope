    mod gcd(a:u32, b:u32) -> (reg result:u32) {
      reg x = a
      reg y = b

      if y != 0 {
        result = nil
        if x > y {
          x -= y
        } else {
          y -= x
        }
      }else{
        result = x // Unset nil
      }
    }

    for a in 1..=100 {
      for b in 1..=100 {
        test "check.gcd({},{})",a,b {
          const z = gcd(a, b)

          waitfor z?

          assert z == __my_cpp_gcd(v1=a, v2=b)
        }
      }
    }
